{
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "color": "color-mix(in oklch, {color.black} 50%, transparent)",
        "offsetX": "{spacing.0}",
        "offsetY": "{spacing.1}",
        "blur": "{spacing.3}"
      }
    },
    "lg": {
      "$value": {
        "color": "color-mix(in oklch, {color.black} 50%, transparent)",
        "offsetX": "{spacing.0}",
        "offsetY": "{spacing.2}",
        "blur": "{spacing.4}"
      }
    },
    "glow": {
      "$value": {
        "color": "color-mix(in oklch, {color.primary.500} 50%, transparent)",
        "offsetX": "{spacing.0}",
        "offsetY": "{spacing.0}",
        "blur": "{spacing.6}"
      }
    }
  }
}
