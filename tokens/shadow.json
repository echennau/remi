{
    "shadow": {
        "$type": "shadow",
        "sm": {
            "$value": {
                "color": "{color.black}",
                "offsetX": "{spacing.0}",
                "offsetY": "{spacing.1}",
                "blur": "{spacing.3}"
            }
        },
        "lg": {
            "$value": {
                "color": "{color.black}",
                "offsetX": "{spacing.0}",
                "offsetY": "{spacing.2}",
                "blur": "{spacing.4}"
            }
        },
        "glow": {
            "$value": {
                "color": "#ff793b80",
                "offsetX": "{spacing.0}",
                "offsetY": "{spacing.0}",
                "blur": "{spacing.6}"
            }
        }
    }
}
