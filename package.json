  "scripts": {
    "build": "style-dictionary build --verbose && cp -r ./styles ./dist",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.2.4",
    "prettier": "^3.8.3",
    "style-dictionary": "^5.4.0",
    "tailwindcss": "^4.2.4"
  }
}
